{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2023",
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client", "node"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    /* Landing page reads library versions straight from package.json so its
       "what's inside" list can never go stale. */
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "collections/*": ["./.source/*"],
      /*
       * Needed whenever @nqlib/nqui is `link:../nqui` (pnpm nqui:local): the linked
       * repo carries its own @types/react, so nqui's .d.ts and this app would see two
       * incompatible React type instances (`--radix-${string}` index-signature errors
       * in the nqgrid shells). Pin one copy. Harmless on the published path — keep it
       * so switching to local never re-breaks typecheck.
       */
      "react": ["./node_modules/@types/react"],
      "react/jsx-runtime": ["./node_modules/@types/react/jsx-runtime"],
      "react-dom": ["./node_modules/@types/react-dom"],
      /*
       * DEV-ONLY: type-resolve @nqlib/nqgrid against the sibling ../nqgrid/src so
       * the editor/typecheck match the engine API that `pnpm dev:local` runs with.
       * The published @nqlib/nqgrid@0.1.0 is STALE and lacks this API. Before the
       * showcase can build/deploy against the published package, publish a current
       * nqgrid and REMOVE these eight mappings (see NQGRID-WORKSPACE.md).
       */
      "@nqlib/nqgrid": ["../nqgrid/src/index.ts"],
      "@nqlib/nqgrid/engine": ["../nqgrid/src/engine/index.ts"],
      "@nqlib/nqgrid/grid": ["../nqgrid/src/grid/index.ts"],
      "@nqlib/nqgrid/sheet": ["../nqgrid/src/sheet/index.ts"],
      "@nqlib/nqgrid/spreadsheet": ["../nqgrid/src/spreadsheet/index.ts"],
      "@nqlib/nqgrid/advanced": ["../nqgrid/src/advanced/index.ts"],
      "@nqlib/nqgrid/configurator": ["../nqgrid/src/configurator/index.ts"],
      "@nqlib/nqgrid/fixtures": ["../nqgrid/src/fixtures/index.ts"],
      /*
       * DEV-ONLY: type-resolve @nqlib/nqgantt against sibling source when iterating
       * with `pnpm dev:local`. Remove or gate when deploy tracks published only.
       * @nqlib/nqgantt-engine is mapped alongside it — nqgantt/src imports the
       * engine as a bare specifier, so without this tsc would typecheck local
       * nqgantt source against the PUBLISHED (possibly older) engine's .d.ts
       * instead of the matching local engine version being tested pre-publish.
       */
      "@nqlib/nqgantt": ["../nqgantt/packages/nqgantt/src/index.ts"],
      "@nqlib/nqgantt/ui": ["../nqgantt/packages/nqgantt/src/ui.ts"],
      "@nqlib/nqgantt/engine": ["../nqgantt/packages/nqgantt/src/engine.ts"],
      "@nqlib/nqgantt/mock": ["../nqgantt/packages/nqgantt/src/mock.ts"],
      "@nqlib/nqgantt/item-gantt-adapter": ["../nqgantt/packages/nqgantt/src/item-gantt-adapter.ts"],
      "@nqlib/nqgantt-engine": ["../nqgantt/packages/nqgantt-engine/src/index.ts"]
    },

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": ["src"],
  "exclude": ["src/nqgantt/lib"]
}
